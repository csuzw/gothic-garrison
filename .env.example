# Copy to .env and adjust as needed. Loaded by SvelteKit and the db package.

# Postgres connection. Matches docker-compose.yml (host port 5433 by default
# to avoid clashing with a local Postgres on 5432). Set DB_PORT below if you
# change it.
DB_PORT=5433
DATABASE_URL=postgres://gothic:gothic@localhost:5433/gothic_garrison

# Better-auth signing secret. Generate one with `openssl rand -hex 32`.
AUTH_SECRET=change-me-in-real-deployments

# Public URL the app is reachable on (used by better-auth for callback URLs).
PUBLIC_APP_URL=http://localhost:5173

# Mail. In dev, point RESEND_API_URL at the local petite-poste mock; any
# non-empty key works. In prod, unset RESEND_API_URL and use your real Resend key.
RESEND_API_KEY=dev-key
RESEND_API_URL=http://localhost:8025
EMAIL_FROM=Gothic Garrison <noreply@gothic-garrison.local>

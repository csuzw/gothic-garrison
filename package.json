{
  "name": "gothic-garrison-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter gothic-garrison dev",
    "dev:mailer": "pnpm --filter petite-poste dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter gothic-garrison test:e2e",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @gothic-garrison/db generate",
    "db:migrate": "pnpm --filter @gothic-garrison/db migrate",
    "db:seed": "pnpm --filter @gothic-garrison/db seed",
    "db:export-seed": "pnpm --filter @gothic-garrison/db export-seed",
    "db:studio": "pnpm --filter @gothic-garrison/db studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
